#: data/org.gnome.Gnote.appdata.xml.in:7 data/org.gnome.Gnote.desktop.in:2 src/recentchanges.cpp:99 src/recentchanges.cpp:121
msgid "Gnote"
msgstr "Gnote"

#: data/org.gnome.Gnote.appdata.xml.in:8
msgid "A simple note-taking application"
msgstr "Қарапайым жазбалар қолданбасы"

#: data/org.gnome.Gnote.appdata.xml.in:10
msgid "Gnote is a simple note-taking application for GNOME desktop environment. It allows you to capture your ideas, link them together using WikiWiki-style links, group together in notebooks and some extra features for everyday use."
msgstr ""
"Gnote — GNOME жұмыс үстелі ортасына арналған қарапайым жазбалар қолданбасы. Ол идеяларыңызды жазып алуға, оларды WikiWiki стиліндегі сілтемелер арқылы өзара байланыстыруға, жазба кітапшаларына топтастыруға мүмкіндік береді және күнделікті пайдалануға арналған қосымша функциялары бар."

#: data/org.gnome.Gnote.appdata.xml.in:13
msgid "Notes can be printed or exported as HTML documents."
msgstr "Жазбаларды басып шығаруға немесе HTML құжаттары ретінде экспорттауға болады."

#: data/org.gnome.Gnote.appdata.xml.in:14
msgid "Gnote also supports synchronization, making it simple to use it on multiple devices."
msgstr "Gnote сондай-ақ синхрондауды қолдайды, бұл оны бірнеше құрылғыда пайдалануды жеңілдетеді."

#: data/org.gnome.Gnote.desktop.in:3
msgid "Take notes, link ideas, and stay organized"
msgstr "Жазбалар жазу, идеяларды байланыстыру және ұйымдасқан болу"

#: data/org.gnome.Gnote.desktop.in:4
msgid "Note-taker"
msgstr "Жазбалармен жұмыс істеу"

#. Translators: Search terms to find this application. Do NOT translate or
#. localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Gnote.desktop.in:6
msgid "notes;idea;link;organize;"
msgstr "жазбалар;идея;сілтеме;ұйымдастыру;"

#: data/org.gnome.Gnote.desktop.in:19
msgid "New Window"
msgstr "Жаңа терезе"

#: data/org.gnome.Gnote.desktop.in:23 src/notebooks/notebook.cpp:196 src/notemanagerbase.cpp:297 src/searchnoteswidget.cpp:343
msgid "New Note"
msgstr "Жаңа жазба"

#: data/org.gnome.gnote.gschema.xml:6
msgid "Enable spellchecking"
msgstr "Емлені тексеруді іске қосу"

#: data/org.gnome.gnote.gschema.xml:7
msgid "If true, misspellings will be underlined in red, and correct spelling suggestions shown in the right-click menu."
msgstr "Егер ақиқат болса, қате жазылған сөздердің асты қызылмен сызылады, ал дұрыс жазу нұсқалары оң жақ шерту мәзірінде көрсетіледі."

#: data/org.gnome.gnote.gschema.xml:11
msgid "Automatically create links when typing"
msgstr "Теру кезінде сілтемелерді автоматты түрде жасау"

#: data/org.gnome.gnote.gschema.xml:12
msgid "Enable this option to automatically create a link, when text matches note title."
msgstr "Мәтін жазба тақырыбына сәйкес келгенде сілтемені автоматты түрде жасау үшін бұл опцияны іске қосыңыз."

#: data/org.gnome.gnote.gschema.xml:16
msgid "Create links for URLs in notes"
msgstr "Жазбалардағы URL мекенжайлары үшін сілтемелер жасау"

#: data/org.gnome.gnote.gschema.xml:17
msgid "Enable this option to create links for URLs in notes."
msgstr "Жазбалардағы URL мекенжайлары үшін сілтемелер жасау үшін бұл опцияны іске қосыңыз."

#: data/org.gnome.gnote.gschema.xml:21
msgid "Enable WikiWord highlighting"
msgstr "WikiWord ерекшелеуді іске қосу"

#: data/org.gnome.gnote.gschema.xml:22
msgid "Enable this option to highlight words ThatLookLikeThis. Clicking the word will create a note with that name."
msgstr "ОсыLookLikeThis сияқты сөздерді түспен ерекшелеу үшін бұл опцияны іске қосыңыз. Сөзді шерту осы атпен жазба жасайды."

#: data/org.gnome.gnote.gschema.xml:26
msgid "Enable Auto bulleted lists"
msgstr "Автоматты маркерленген тізімдерді іске қосу"

#: data/org.gnome.gnote.gschema.xml:27
msgid "Enable this option if you want bulleted lists to be automatic when you place - or * at the beginning of a line."
msgstr "Жолдың басына - немесе * таңбасын қойғанда маркерленген тізімдердің автоматты түрде жасалуын қаласаңыз, бұл опцияны іске қосыңыз."

#: data/org.gnome.gnote.gschema.xml:31
msgid "Enable Middle-Click Paste On Icon"
msgstr "Таңбашаға ортаңғы батырмамен шерту арқылы кірістіруді іске қосу"

#: data/org.gnome.gnote.gschema.xml:32
msgid "Enable this option if you want to be able to middle-click the Gnote icon to paste timestamped content into the Start Here note."
msgstr "Уақыт белгісі бар мазмұнды «Осыдан бастау» жазбасына кірістіру үшін Gnote таңбашасын тышқанның ортаңғы батырмасымен шерту мүмкіндігін қаласаңыз, бұл опцияны іске қосыңыз."

#: data/org.gnome.gnote.gschema.xml:36
msgid "Enable custom font"
msgstr "Таңдаулы қаріпті іске қосу"

#: data/org.gnome.gnote.gschema.xml:37
msgid "If true, the font name set in custom-font-face will be used as the font when displaying notes. Otherwise the desktop default font will be used."
msgstr "Егер ақиқат болса, жазбаларды көрсету кезінде custom-font-face ішінде орнатылған қаріп аты пайдаланылады. Әйтпесе, жұмыс үстелінің бастапқы қаріпі пайдаланылады."

#: data/org.gnome.gnote.gschema.xml:41
msgid "Custom Font Face"
msgstr "Таңдаулы қаріп гарнитурасы"

#: data/org.gnome.gnote.gschema.xml:42
msgid "If enable-custom-font is true, the font name set here will be used as the font when displaying notes."
msgstr "Егер enable-custom-font мәні ақиқат болса, мұнда орнатылған қаріп аты жазбаларды көрсету кезінде қаріп ретінде пайдаланылады."

#: data/org.gnome.gnote.gschema.xml:46
msgid "Background color for the highlighted text"
msgstr "Түспен ерекшеленген мәтін үшін фон түсі"

#: data/org.gnome.gnote.gschema.xml:47
msgid "When text is highlighted, use this color for background. A string gdk_rgba_parse() accepts."
msgstr "Мәтін түспен ерекшеленгенде, фон үшін осы түсті пайдаланыңыз. gdk_rgba_parse() қабылдайтын жол."

#: data/org.gnome.gnote.gschema.xml:51
msgid "Color for the highlighted text"
msgstr "Түспен ерекшеленген мәтін түсі"

#: data/org.gnome.gnote.gschema.xml:52
msgid "When text is highlighted, use this color for text. A string gdk_rgba_parse() accepts."
msgstr "Мәтін түспен ерекшеленгенде, мәтін үшін осы түсті пайдаланыңыз. gdk_rgba_parse() қабылдайтын жол."

#: data/org.gnome.gnote.gschema.xml:56
msgid "Start Here Note"
msgstr "«Осыдан бастау» жазбасы"

#: data/org.gnome.gnote.gschema.xml:57
msgid "The note URI of the note that should be considered the \"Start Here\" note, which is always placed at the bottom of the Gnote note menu and also accessible by hotkey."
msgstr "«Осыдан бастау» жазбасы ретінде қарастырылуы тиіс жазбаның URI мекенжайы, ол әрқашан Gnote жазба мәзірінің төменгі жағында орналасады және оған жедел перне арқылы қол жеткізуге болады."

#: data/org.gnome.gnote.gschema.xml:61
msgid "Minimum number of notes to show in menu"
msgstr "Мәзірде көрсетілетін жазбалардың минималды саны"

#: data/org.gnome.gnote.gschema.xml:62
msgid "Integer determining the minimum number of notes to show in the Gnote note menu."
msgstr "Gnote жазба мәзірінде көрсетілетін жазбалардың минималды санын анықтайтын бүтін сан."

#: data/org.gnome.gnote.gschema.xml:66
msgid "List of pinned notes"
msgstr "Бекітілген жазбалар тізімі"

#: data/org.gnome.gnote.gschema.xml:67
msgid "Whitespace-separated list of note URIs for notes that should always appear in the Gnote note menu."
msgstr "Gnote жазба мәзірінде әрқашан пайда болуы тиіс жазбалардың бос орынмен бөлінген URI тізімі."

#: data/org.gnome.gnote.gschema.xml:71
msgid "Is main window maximized"
msgstr "Негізгі терезе жайылған ба"

#: data/org.gnome.gnote.gschema.xml:72
msgid "If true, Gnote window will be maximized."
msgstr "Егер ақиқат болса, Gnote терезесі толық экранға жайылады."

#: data/org.gnome.gnote.gschema.xml:76
msgid "Saved height of Search window"
msgstr "Іздеу терезесінің сақталған биіктігі"

#: data/org.gnome.gnote.gschema.xml:77
msgid "Determines pixel height of Search window; stored on Gnote exit."
msgstr "Іздеу терезесінің пиксельмен биіктігін анықтайды; Gnote жабылғанда сақталады."

#: data/org.gnome.gnote.gschema.xml:81
msgid "Saved width of Search window"
msgstr "Іздеу терезесінің сақталған ені"

#: data/org.gnome.gnote.gschema.xml:82
msgid "Determines pixel width of Search window; stored on Gnote exit."
msgstr "Іздеу терезесінің пиксельмен енін анықтайды; Gnote жабылғанда сақталады."

#: data/org.gnome.gnote.gschema.xml:86
msgid "Saved splitter position of Search window splitter."
msgstr "Іздеу терезесі бөлгішінің сақталған орны."

#: data/org.gnome.gnote.gschema.xml:87
msgid "Determines Search window splitter position in pixels; stored on Gnote exit."
msgstr "Іздеу терезесі бөлгішінің орнын пиксельмен анықтайды; Gnote жабылғанда сақталады."

#: data/org.gnome.gnote.gschema.xml:91
msgid "Saved sorting of the Search window."
msgstr "Іздеу терезесінің сақталған сұрыптауы."

#: data/org.gnome.gnote.gschema.xml:92
msgid "Determines Search window initial sorting."
msgstr "Іздеу терезесінің бастапқы сұрыптауын анықтайды."

#: data/org.gnome.gnote.gschema.xml:96
msgid "FUSE Mounting Timeout (ms)"
msgstr "FUSE тіркеудің күту уақыты (мс)"

#: data/org.gnome.gnote.gschema.xml:97
msgid "Time (in milliseconds) Gnote should wait for a response when using FUSE to mount a sync share."
msgstr "Синхрондау ортақ ресурсын тіркеу үшін FUSE пайдалану кезінде Gnote жауапты күтуі тиіс уақыт (миллисекундпен)."

#: data/org.gnome.gnote.gschema.xml:101
msgid "SSHFS Remote Synchronization Folder"
msgstr "SSHFS қашықтағы синхрондау бумасы"

#: data/org.gnome.gnote.gschema.xml:102
msgid "Path on SSH server to Gnote synchronization directory (optional)."
msgstr "SSH серверіндегі Gnote синхрондау бумасына жол (міндетті емес)."

#: data/org.gnome.gnote.gschema.xml:106
msgid "SSHFS Synchronization Server URL"
msgstr "SSHFS синхрондау серверінің URL мекенжайы"

#: data/org.gnome.gnote.gschema.xml:107
msgid "URL of SSH server containing Gnote synchronization directory."
msgstr "Gnote синхрондау бумасы бар SSH серверінің URL мекенжайы."

#: data/org.gnome.gnote.gschema.xml:111
msgid "SSHFS Remote Synchronization User Name"
msgstr "SSHFS қашықтағы синхрондау пайдаланушы аты"

#: data/org.gnome.gnote.gschema.xml:112
msgid "User name to use when connecting to the synchronization server via SSH."
msgstr "Синхрондау серверіне SSH арқылы қосылу кезінде пайдаланылатын пайдаланушы аты."

#: data/org.gnome.gnote.gschema.xml:116
msgid "SSHFS Synchronization Server Port"
msgstr "SSHFS синхрондау серверінің порты"

#: data/org.gnome.gnote.gschema.xml:117
msgid "The port to use when connecting to the synchronization server via SSH."
msgstr "Синхрондау серверіне SSH арқылы қосылу кезінде пайдаланылатын порт."

#: data/org.gnome.gnote.gschema.xml:121
msgid "Link Updating Behavior on Note Rename"
msgstr "Жазбаның атын өзгерткендегі сілтемені жаңарту әрекеті"

#: data/org.gnome.gnote.gschema.xml:122
msgid ""
"Integer value indicating if there is a preference to always perform a specific link updating behavior when a note is renamed, instead of prompting the user. The values map to an internal enumeration. 0 indicates that the user wishes to be prompted when renaming a note may impact "
"links that exist in other notes. 1 indicates that links should automatically be removed. 2 indicates that link text should be updated to the new note name so that it will continue linking to the renamed note."
msgstr ""
"Жазбаның аты өзгертілгенде пайдаланушыдан сұраудың орнына, әрқашан белгілі бір сілтеме жаңарту әрекетін орындау қалауы бар екенін көрсететін бүтін мән. Мәндер ішкі санаққа сәйкес келеді. 0 пайдаланушы жазбаның атын өзгерту басқа жазбалардағы сілтемелерге әсер етуі мүмкін болғанда "
"сұраудың шығуын қалайтынын білдіреді. 1 сілтемелерді автоматты түрде өшіру керектігін білдіреді. 2 сілтеме мәтіні өзгертілген жазбаға сілтеме жасай беруі үшін жаңа жазба атына жаңартылуы тиіс екенін білдіреді."

#: data/org.gnome.gnote.gschema.xml:126 data/org.gnome.gnote.gschema.xml:136 data/org.gnome.gnote.gschema.xml:141
msgid "Deprecated"
msgstr "Ескірген"

#: data/org.gnome.gnote.gschema.xml:127 data/org.gnome.gnote.gschema.xml:142
msgid "This key is deprecated and its value is ignored."
msgstr "Бұл кілт ескірген және оның мәні еленбейді."

#: data/org.gnome.gnote.gschema.xml:131
msgid "Use status icon, when started as an application"
msgstr "Қолданба ретінде іске қосылғанда қалып-күй таңбашасын пайдалану"

#: data/org.gnome.gnote.gschema.xml:132
msgid "Deprecated, has no effect."
msgstr "Ескірген, әсері жоқ."

#: data/org.gnome.gnote.gschema.xml:137
msgid "This setting is deprecated and its value is ignored"
msgstr "Бұл баптау ескірген және оның мәні еленбейді"

#: data/org.gnome.gnote.gschema.xml:146
msgid "Use client side window decorations"
msgstr "Клиенттік терезе безендірулерін пайдалану"

#: data/org.gnome.gnote.gschema.xml:147
msgid ""
"Should Gnote draw its window titlebar, or leave that to window manager. Possible values are 'enabled' to draw them, 'disabled' to leave them to window manager, or a comma separated list of desktop environments, where Gnote should draw decorations itself. Requires application restart."
msgstr ""
"Gnote өз терезесінің тақырып жолағын өзі салуы керек пе, әлде оны терезе менеджеріне қалдыруы керек пе. Мүмкін мәндер: оларды салу үшін «enabled», терезе менеджеріне қалдыру үшін «disabled» немесе Gnote безендірулерді өзі салуы тиіс жұмыс үстелі орталарының үтірмен бөлінген тізімі. "
"Қолданбаны қайта іске қосуды талап етеді."

#: data/org.gnome.gnote.gschema.xml:151
msgid "Preferred color scheme to use"
msgstr "Пайдалануға арналған таңдаулы түс схемасы"

#: data/org.gnome.gnote.gschema.xml:152
msgid "The theme variant to use. Possible values are empty string to follow the system, 'dark' and 'light'."
msgstr "Пайдаланылатын тема нұсқасы. Мүмкін мәндер: жүйені бақылау үшін бос жол, «dark» (күңгірт) және «light» (ашық)."

#: data/org.gnome.gnote.gschema.xml:163
msgid "HTML Export Last Directory"
msgstr "HTML экспорттаудың соңғы бумасы"

#: data/org.gnome.gnote.gschema.xml:164
msgid "The last directory a note was exported to using the Export To HTML plugin."
msgstr "«HTML-ге экспорттау» плагині арқылы жазба экспортталған соңғы бума."

#: data/org.gnome.gnote.gschema.xml:168
msgid "HTML Export Linked Notes"
msgstr "HTML-ге экспортталған сілтемеленген жазбалар"

#: data/org.gnome.gnote.gschema.xml:169
msgid "The last setting for the 'Export linked notes' checkbox in the Export to HTML plugin."
msgstr "«HTML-ге экспорттау» плагиніндегі «Сілтемеленген жазбаларды экспорттау» жалаушасының соңғы мәні."

#: data/org.gnome.gnote.gschema.xml:173
msgid "HTML Export All Linked Notes"
msgstr "Барлық сілтемеленген жазбаларды HTML-ге экспорттау"

#: data/org.gnome.gnote.gschema.xml:174
msgid ""
"The last setting for the 'Include all other linked notes' checkbox in the Export to HTML plugin. This setting is used in conjunction with the 'HTML Export Linked Notes' setting and is used to specify whether all notes (found recursively) should be included during an export to HTML."
msgstr ""
"«HTML-ге экспорттау» плагиніндегі «Барлық басқа сілтемеленген жазбаларды қосу» жалаушасының соңғы мәні. Бұл параметр «HTML-ге экспортталған сілтемеленген жазбалар» параметрімен бірге қолданылады және HTML-ге экспорттау кезінде барлық жазбалардың (рекурсивті түрде табылған) қосылу "
"керектігін көрсету үшін пайдаланылады."

#: data/org.gnome.gnote.gschema.xml:180
msgid "Synchronization Client ID"
msgstr "Синхрондау клиентінің идентификаторы"

#: data/org.gnome.gnote.gschema.xml:181
msgid "Unique identifier for this Gnote client, used when communicating with a synchronization server."
msgstr "Синхрондау серверімен байланысу кезінде пайдаланылатын осы Gnote клиентінің бірегей идентификаторы."

#: data/org.gnome.gnote.gschema.xml:185
msgid "Synchronization Local Server Path"
msgstr "Синхрондаудың жергілікті сервер жолы"

#: data/org.gnome.gnote.gschema.xml:186
msgid "Path to the synchronization server when using the filesystem synchronization service addin."
msgstr "Файлдық жүйені синхрондау қызметінің қосымшасын пайдалану кезіндегі синхрондау серверіне жол."

#: data/org.gnome.gnote.gschema.xml:190
msgid "Selected Synchronization Service Addin"
msgstr "Таңдалған синхрондау қызметінің плагині"

#: data/org.gnome.gnote.gschema.xml:191
msgid "Unique identifier for the currently configured note synchronization service addin."
msgstr "Қазіргі уақытта конфигурацияланған жазбаларды синхрондау қызметі плагинінің бірегей идентификаторы."

#: data/org.gnome.gnote.gschema.xml:195
msgid "Note Synchronization Conflict Saved Behavior"
msgstr "Жазбаны синхрондау қайшылығының сақталған әрекеті"

#: data/org.gnome.gnote.gschema.xml:196
msgid ""
"Integer value indicating if there is a preference to always perform a specific behavior when a conflict is detected, instead of prompting the user. The values map to an internal enumeration. 0 indicates that the user wishes to be prompted when a conflict occurs, so that they may "
"handle each conflict situation on a case-by-case basis."
msgstr ""
"Қайшылық анықталған кезде пайдаланушыдан сұраудың орнына әрқашан белгілі бір әрекетті орындау қалауы бар екенін көрсететін бүтін мән. Мәндер ішкі санаққа сәйкес келеді. 0 пайдаланушы әрбір қайшылық жағдайын жеке-жеке шешу үшін қайшылық туындаған кезде сұраудың шығуын қалайтынын "
"білдіреді."

#: data/org.gnome.gnote.gschema.xml:200
msgid "Automatic Background Synchronization Timeout"
msgstr "Автоматты фондық синхрондаудың күту уақыты"

#: data/org.gnome.gnote.gschema.xml:201
msgid "Integer value indicating how frequently to perform a background sync of your notes (when sync is configured). Any value less than 1 indicates that autosync is disabled. The lowest acceptable positive value is 5. Value is in minutes."
msgstr "Жазбаларыңыздың фондық синхрондауын қаншалықты жиі орындау керектігін көрсететін бүтін мән (синхрондау конфигурацияланған болса). 1-ден кіші кез келген мән автоматты синхрондаудың сөндірілгенін білдіреді. Ең төменгі рұқсат етілген оң мән — 5. Мән минутпен берілген."

#: data/org.gnome.gnote.gschema.xml:208
msgid "Online directory URI"
msgstr "Желідегі буманың URI мекенжайы"

#: data/org.gnome.gnote.gschema.xml:209
msgid "URI to online directory where notes are synchronized to."
msgstr "Жазбалар синхрондалатын желідегі буманың URI мекенжайы."

#: data/org.gnome.gnote.gschema.xml:215
msgid "Accept SSL Certificates"
msgstr "SSL сертификаттарын қабылдау"

#: data/org.gnome.gnote.gschema.xml:216
msgid "Use wdfs option \"-ac\" to accept SSL certificates without prompting the user."
msgstr "SSL сертификаттарын пайдаланушыдан сұрамай қабылдау үшін wdfs «-ac» опциясын пайдаланыңыз."

#: data/org.gnome.gnote.gschema.xml:220
msgid "Share URL"
msgstr "Ортақ ресурс URL мекенжайы"

#: data/org.gnome.gnote.gschema.xml:221
msgid "WebDAV share URL where notes are synchronized to."
msgstr "Жазбалар синхрондалатын WebDAV ортақ ресурстың URL мекенжайы."

#: data/org.gnome.gnote.gschema.xml:225
msgid "Share username"
msgstr "Ортақ ресурстың пайдаланушы аты"

#: data/org.gnome.gnote.gschema.xml:226
msgid "Username to access WebDAV share."
msgstr "WebDAV ортақ ресурсына қол жеткізу үшін пайдаланушы аты."

#: data/org.gnome.gnote.gschema.xml:232
msgid "Timestamp format"
msgstr "Уақыт таңбасының пішімі"

#: data/org.gnome.gnote.gschema.xml:233
msgid "The date format that is used for the timestamp. It follows the format of strftime(3)."
msgstr "Уақыт таңбасы үшін пайдаланылатын күн пішімі. Ол strftime(3) пішіміне сәйкес келеді."

#: data/org.gnome.gnote.gschema.xml:239
msgid "Time between checks"
msgstr "Тексерулер арасындағы уақыт"

#: data/org.gnome.gnote.gschema.xml:240
msgid "Time interval between note directory checks (in seconds). Min value is 5."
msgstr "Жазбалар бумасын тексеру арасындағы уақыт аралығы (секундпен). Минималды мән — 5."

